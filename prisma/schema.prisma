generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id Int @default(autoincrement()) @id
  completed Boolean @default(false)
  name String
  phone String
  time DateTime
  date DateTime
  coast Int
  service String
  description String?
  comment String?
}